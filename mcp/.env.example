# ============================================================
# Asset Management MCP Server - Environment Variables
# cp .env.example .env して値を設定してください
# ============================================================

# HTTP port
PORT=3000

# 公開URL（OAuth metadataに使用）
# 例: https://your-server.sakura.ne.jp
BASE_URL=https://your-vps-hostname-here.com

# OAuthログイン用パスワード（シングルユーザー）
# 生成例: openssl rand -base64 32
MCP_PASSWORD=change-me-to-a-strong-password

# JWT署名秘密鍵（必ず変更すること）
# 生成例: openssl rand -base64 48
JWT_SECRET=change-me-to-a-secret-key-at-least-32-chars

# FastAPI backend
BACKEND_URL=http://localhost:8000
BACKEND_USERNAME=your-username
BACKEND_PASSWORD=your-password
