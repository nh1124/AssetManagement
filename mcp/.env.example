# ============================================================
# Asset Management MCP Server
# Copy this file to .env when running the MCP server locally.
# ============================================================

# HTTP transport port for npm run start:http / npm run dev:http.
PORT=3000

# Public base URL used in OAuth metadata.
# Local example: http://localhost:3000
# Remote example: https://asset-mcp.example.com
BASE_URL=http://localhost:3000

# Single-user password used by the OAuth login screen.
# Generate example: openssl rand -base64 32
MCP_PASSWORD=change-me-to-a-strong-password

# JWT signing secret for MCP OAuth tokens.
# Generate example: openssl rand -base64 48
JWT_SECRET=change-me-to-a-secret-key-at-least-32-chars

# FastAPI backend connection used by tools and resources.
BACKEND_URL=http://localhost:8000
BACKEND_USERNAME=your-username
BACKEND_PASSWORD=your-password
