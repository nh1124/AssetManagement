{
  "name": "asset-management-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for personal asset management (NISA / DC / employee stock ownership)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "start:http": "node dist/server-http.js",
    "dev": "node --import tsx src/index.ts",
    "dev:http": "node --import tsx src/server-http.ts",
    "build": "node ./node_modules/typescript/bin/tsc",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit",
    "smoke": "node scripts/smoke.mjs",
    "clean": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\""
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
